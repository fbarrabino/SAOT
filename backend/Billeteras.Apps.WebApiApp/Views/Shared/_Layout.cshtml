@{
    var currentSource = ViewData["Source"] as string ?? "mock";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Unificador de Billeteras</title>
    <style>
        body {
            font-family: sans-serif;
            margin: 40px auto;
            max-width: 900px;
            line-height: 1.6;
            color: #333;
            background-color: #fcfcfc;
            padding: 0 10px;
        }
        header {
            border-bottom: 2px solid #ccc;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }
        nav a {
            margin-right: 15px;
            color: #0066cc;
            text-decoration: none;
            font-weight: bold;
        }
        nav a:hover {
            text-decoration: underline;
        }
        .container {
            min-height: 400px;
        }
        footer {
            margin-top: 40px;
            border-top: 1px solid #ddd;
            padding-top: 20px;
            font-size: 0.9em;
            color: #666;
            text-align: center;
        }
        .mode-banner {
            padding: 12px;
            margin-bottom: 20px;
            border-radius: 4px;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .mode-banner.mock {
            background-color: #e6f7ff;
            border: 1px solid #91d5ff;
            color: #0050b3;
        }
        .mode-banner.db {
            background-color: #f6ffed;
            border: 1px solid #b7eb8f;
            color: #389e0d;
        }
        .btn-toggle {
            display: inline-block;
            padding: 6px 12px;
            font-size: 13px;
            font-weight: bold;
            line-height: 1.4;
            text-align: center;
            white-space: nowrap;
            vertical-align: middle;
            cursor: pointer;
            border: 1px solid #ccc;
            border-radius: 4px;
            background-color: #fff;
            text-decoration: none;
            color: #333;
        }
        .btn-toggle:hover {
            background-color: #e6e6e6;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            margin-bottom: 20px;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: left;
        }
        th {
            background-color: #f2f2f2;
            font-weight: bold;
        }
        tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        .card {
            border: 1px solid #ddd;
            padding: 20px;
            background: #fff;
            border-radius: 4px;
            margin-bottom: 20px;
        }
        .btn-detail {
            color: #0066cc;
            text-decoration: none;
            font-weight: bold;
        }
        .btn-detail:hover {
            text-decoration: underline;
        }
        .error-message {
            background-color: #fff2f0;
            border: 1px solid #ffccc7;
            color: #ff4d4f;
            padding: 12px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-weight: bold;
        }
        .badge {
            display: inline-block;
            padding: 3px 6px;
            font-size: 11px;
            font-weight: bold;
            border-radius: 3px;
            color: #fff;
        }
        .badge.ingreso {
            background-color: #52c41a;
        }
        .badge.egreso {
            background-color: #ff4d4f;
        }
    </style>
</head>
<body>
    <header>
        <h2>Unificador de Billeteras Virtuales</h2>
        <nav>
            <a href="/?source=@currentSource">Listado de Cuentas</a>
        </nav>
    </header>

    <div class="container">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="error-message">
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="mode-banner @currentSource">
            <span>
                Modo Activo: @(currentSource == "db" ? "Base de Datos (TP-04)" : "Simulado en Memoria (TP-02)")
            </span>
            @if (currentSource == "db")
            {
                <a href="?source=mock" class="btn-toggle">Cambiar a Modo Simulado (TP-02)</a>
            }
            else
            {
                <a href="?source=db" class="btn-toggle">Cambiar a Modo Base de Datos (TP-04)</a>
            }
        </div>

        @RenderBody()
    </div>

    <footer>
        <p>&copy; @DateTime.Now.Year - Adaptación de Consigna TUP · Unificador de Billeteras Virtuales</p>
    </footer>
</body>
</html>
